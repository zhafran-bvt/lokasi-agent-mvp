OPENAI_API_KEY=sk-proj-YOUR_API_KEY_HERE_REPLACE_ME
MODEL=gpt-5-mini

APP_NAME=Lokasi Intelligence Staging
APP_URL=https://preprod.lokasi.com/intelligence
APP_EMAIL=your-email@example.com
APP_PASSWORD="your-password-here"

HEADLESS=true
DATA_DIR=./data
BASELINE_NAME=lokasi-preprod
MAX_PAGES=20
MAX_NAV_LINKS_PER_PAGE=20
MAX_ACTIONS_PER_PAGE=6
ALLOW_DESTRUCTIVE=false
REQUEST_TIMEOUT_MS=20000
NAVIGATION_TIMEOUT_MS=30000
LLM_TIMEOUT_MS=60000
RUN_TIMEOUT_MS=900000
SPATIAL_ANALYSIS_CATCHMENT_LOCATION_QUERY=Monas, Jakarta
SPATIAL_ANALYSIS_CATCHMENT_RADIUS_METERS=100
FOCUSED_WORKFLOW=spatial-analysis-workflow
DATASET_EXPLORER_PROVINCE=DKI Jakarta
DATASET_EXPLORER_SPATIAL_AGGREGATIONS=Point,Polygon,H3,Administrative Area,Geohash,Line
MAIN_FEATURES=Spatial Analysis,Dataset Explorer,Dataset Management,Project Management
SECONDARY_FEATURES=Search,Settings,Expand,Collapse,My Account

# Optional: set these if login heuristics fail on your app
LOGIN_EMAIL_SELECTOR=
LOGIN_PASSWORD_SELECTOR=
LOGIN_SUBMIT_SELECTOR=
